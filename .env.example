# V-Genesis 環境設定
# このファイルを .env にコピーして設定してください

# Claude APIキー (https://console.anthropic.com/ で取得)
CLAUDE_API_KEY=sk-ant-...

# Anthropic APIキー（レガシー互換）
ANTHROPIC_API_KEY=

# サーバーポート（デフォルト: 8765）
PORT=8765

# IOPaintの実行ファイルパス（オプション）
# 例: C:\Users\YourName\Downloads\IOPaint\IOPaint.exe
IOPAINT_PATH=

# VOICEVOXの実行ファイルパス（オプション）
# 例: C:\Users\YourName\AppData\Local\Programs\VOICEVOX\VOICEVOX.exe
VOICEVOX_PATH=
