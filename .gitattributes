# Handle line endings automatically
* text=auto

# Force Unix line endings for scripts
*.sh text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.mp4 binary
*.mov binary
*.avi binary
*.wav binary
*.mp3 binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
